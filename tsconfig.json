{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "lib": ["es2016", "dom"],
      "rootDir": "./build",
      "outDir": "./src",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "forceConsistentCasingInFileNames": true,
      "moduleResolution": "node",
    },
    "include": [
      "build/**/*"
    ],
    "exclude": [
      "node_modules",
      "**/*.test.ts"
    ]
  }